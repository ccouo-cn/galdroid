<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 底层：半透明黑 -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <solid android:color="#E8111111" />
        </shape>
    </item>

    <!-- 磨砂噪声层（暂时注释，等有图再放开）
    <item>
	<bitmap
	android:src="@drawable/bg_noise"
	android:tileMode="repeat"
	android:alpha="0.08" />
    </item>
    -->

    <!-- 顶部微高光 -->
    <item
        android:top="0dp"
        android:left="0dp"
        android:right="0dp"
        android:bottom="40dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:startColor="#22FFFFFF"
                android:endColor="@android:color/transparent"
                android:angle="270" />
        </shape>
    </item>

    <!-- 边缘描边 -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="#22FFFFFF" />
        </shape>
    </item>

</layer-list>

